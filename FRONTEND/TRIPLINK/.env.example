# Copy to .env and set your PC's Wi‑Fi IP (ipconfig → IPv4). Rebuild APK after changing.
# Backend must listen on all interfaces, e.g.  python manage.py runserver 0.0.0.0:8000
# Production (Render)
EXPO_PUBLIC_API_BASE=https://rohan-rai-triplink.onrender.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Local dev (same Wi‑Fi as PC)
# EXPO_PUBLIC_API_BASE=http://192.168.1.100:8000
